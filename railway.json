{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "gunicorn --config gunicorn.conf.py --worker-class=gthread --workers=2 --threads=8 --bind 0.0.0.0:$PORT --timeout=120 server:app",
    "healthcheckPath": "/api/snapshot",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
